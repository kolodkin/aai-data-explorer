{
  "name": "queryview",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "workspaces": [
    "frontend"
  ],
  "scripts": {
    "backend": "uv run uvicorn queryview.main:app --reload --port 8000",
    "frontend": "npm run dev -w frontend",
    "dev": "concurrently -n backend,frontend -c blue,magenta \"npm run backend\" \"npm run frontend\"",
    "build": "npm run build -w frontend",
    "start": "SERVE_STATIC=1 uv run queryview-backend",
    "preview": "npm run build && npm run start"
  },
  "devDependencies": {
    "concurrently": "^9.2.1"
  }
}
